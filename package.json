{
  "name": "minecraft",
  "version": "0.1.0",
  "private": false,
  "description": "Pulumi Kubernetes stack for a minimal Minecraft server deployment.",
  "type": "module",
  "scripts": {
    "up": "pulumi up --yes --stack ${PULUMI_STACK:-prod}",
    "preview": "pulumi preview --stack ${PULUMI_STACK:-prod}",
    "destroy": "pulumi destroy --yes --stack ${PULUMI_STACK:-prod}"
  },
  "dependencies": {
    "@pulumi/pulumi": "^3.130.0",
    "@pulumi/kubernetes": "^4.12.0"
  },
  "devDependencies": {},
  "engines": {
    "bun": ">=1.1.0"
  }
}